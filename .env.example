# API 密钥（逗号分隔），用于鉴权；务必在生产环境中修改
TTS_API_KEYS=dev-tts-api-key-change-me

# API 监听地址（Docker/服务器部署通常保持 0.0.0.0）
TTS_API_HOST=0.0.0.0

# API 监听端口（宿主机映射端口由 docker-compose 决定）
TTS_API_PORT=8000

# 推理设备，例如：cpu / cuda:0 / cuda:1
TTS_DEVICE=cuda:0

# 模型路径（宿主机路径），默认使用仓库内 models 目录
TTS_MODEL_PATH=./models/k2-fsa/OmniVoice

# 访问限流：每个 API Key 每秒请求上限
TTS_RATE_LIMIT_QPS=10

# 访问限流：每个 API Key 每日请求上限
TTS_RATE_LIMIT_DAILY=100000

# WebSocket：每个 API Key 最大并发连接数
TTS_WS_MAX_CONNECTIONS=5

# 幂等键 TTL（秒），用于避免重复请求导致的重复扣额度/重复生成
TTS_IDEMPOTENCY_TTL=86400

# 是否返回带音调拼音（例如 nǐ hǎo）
TTS_PINYIN_WITH_TONE=true

# 容器可见 GPU（Docker + NVIDIA Toolkit 常用）；也可为 0 或 0,1
NVIDIA_VISIBLE_DEVICES=all
